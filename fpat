local function resolveColorFromTeamName(teamName)
    if not teamName or teamName == "UNKNOWN" then return nil end
    local lower = teamName:lower()
    for key, col in pairs(TEAM_COLORS) do
        if lower:find(key, 1, true) then
            return col
        end
    end
    return nil
end

local function getTeamData(player)
    local char = getPlayerCharacter(player)
    local teamName, teamColor, teamLabel = nil, nil, nil

    if _G.TeamsManager then
        local subject = char or player
        teamName = _G.TeamsManager.GetAssignedTeam(subject)
        local resolvedName, teamInfo = _G.TeamsManager.GetTeamInfo(subject)
        if teamInfo then
            teamName = resolvedName or teamName
            teamColor = teamInfo.Color
            teamLabel = teamInfo.DisplayName or teamName
        end
    end

    if (not teamName or teamName == "UNKNOWN") and player then
        teamName = player:GetAttribute("teamname")
    end
    if (not teamName or teamName == "UNKNOWN") and char then
        teamName = char:GetAttribute("teamname")
    end

    if not teamColor and player then
        teamColor = player:GetAttribute("teamcolor")
    end
    if not teamColor and char then
        teamColor = char:GetAttribute("teamcolor")
    end
    if not teamColor then
        teamColor = resolveColorFromTeamName(teamName)
    end

    teamLabel = teamLabel or teamName or "Unknown"
    if teamLabel == "UNKNOWN" then
        teamLabel = "Unknown"
    end

    return teamName, teamColor, teamLabel
end

local function getTeamColor(player)
    if not _G.Config.ESPShowTeamColor then
        return _G.Config.ESPBoxColor
    end
    local _, teamColor = getTeamData(player)
    return teamColor or _G.Config.ESPBoxColor
end

local function getTeamLabel(player)
    local _, _, teamLabel = getTeamData(player)
