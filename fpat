local function getDrawParent()
    if typeof(gethui) == "function" then
        return gethui()
    end
    return CoreGui
end

local function getRole(plr)
    local ok, role = pcall(function()
        return plr:GetRoleInGroup(MOD_GROUP_ID)
    end)
    return (ok and role) or "Unknown"
end

local function isModerator(plr)
    if not plr or plr == LocalPlayer then return false end
    local ok, inGroup = pcall(function() return plr:IsInGroup(MOD_GROUP_ID) end)
    if not ok or not inGroup then return false end
    return MOD_ROLES[getRole(plr)] == true
end

local function refreshModeratorCache()
    for _, plr in ipairs(Players:GetPlayers()) do
        if isModerator(plr) then
            ModeratorCacheByUserId[plr.UserId] = getRole(plr)
        else
            ModeratorCacheByUserId[plr.UserId] = nil
        end
    end
end

local function highlightModerator(plr)
    if not plr or not plr.Character then return end
    local char = plr.Character
    local hl = char:FindFirstChild("ModHighlight")
    if not hl then
        hl = Instance.new("Highlight")
        hl.Name = "ModHighlight"
        hl.Parent = char
    end
    hl.FillColor = _G.Config.ModFillColor or Color3.fromRGB(220, 88, 88)
    hl.OutlineColor = _G.Config.ModOutlineColor or Color3.fromRGB(255, 210, 200)
    hl.FillTransparency = 0.55
    hl.OutlineTransparency = 0.2
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Enabled = true
end

local function removeModeratorHighlight(plr)
    if not plr or not plr.Character then return end
    local hl = plr.Character:FindFirstChild("ModHighlight")
    if hl then hl:Destroy() end
end

local function bindModeratorHighlight(plr)
    if moderatorHighlightConns[plr] then return end
    moderatorHighlightConns[plr] = plr.CharacterAdded:Connect(function()
        task.wait(0.35)
        if _G.Config.ModESPEnabled and isModerator(plr) then
            highlightModerator(plr)
        end
    end)
end

local function unbindModeratorHighlight(plr)
    local conn = moderatorHighlightConns[plr]
    if conn then
        conn:Disconnect()
        moderatorHighlightConns[plr] = nil
    end
    removeModeratorHighlight(plr)
end

function updateAllModeratorHighlights()
    refreshModeratorCache()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if _G.Config.ModESPEnabled and isModerator(plr) then
            highlightModerator(plr)
            bindModeratorHighlight(plr)
        else
            unbindModeratorHighlight(plr)
        end
