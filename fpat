-- 5.45 BULLET TRACERS (BulletHandler_client hook)
-- ==========================================
local function wrapBulletClosure(fn)
    if typeof(newcclosure) == "function" then
        return newcclosure(fn)
    end
    return fn
end

local function getTracerParent()
    return workspace:FindFirstChildOfClass("Terrain") or workspace
end

local function buildTracerRaycastParams()
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local filter = {}
    local char = LocalPlayer.Character or getPlayerCharacter(LocalPlayer)
    if char then
        table.insert(filter, char)
    end
    if Camera then
        table.insert(filter, Camera)
    end
    raycastParams.FilterDescendantsInstances = filter
    return raycastParams
end

local function resolveTracerEndPos(origin, direction)
    local maxDist = _G.Config.TracerMaxDistance or 500
    direction = direction.Unit
    local ray = workspace:Raycast(origin, direction * maxDist, buildTracerRaycastParams())
    return ray and ray.Position or (origin + direction * maxDist)
end

local Debris = game:GetService("Debris")

local function createNeonTracerPart(origin, endPos, color, thickness, lifetime, withGlow, shrinkWidth)
    local distance = (origin - endPos).Magnitude
    if distance < 0.05 then return end

    lifetime = math.clamp(tonumber(lifetime) or 0.8, 0.2, 5)

    local tracer = Instance.new("Part")
    tracer.Name = "EzekielTracer"
    tracer.Anchored = true
    tracer.CanCollide = false
    tracer.CanQuery = false
    tracer.CanTouch = false
    tracer.CastShadow = false
    tracer.Material = Enum.Material.Neon
    tracer.Color = color
    tracer.Transparency = 0
    tracer.Size = Vector3.new(thickness, thickness, distance)
    tracer.CFrame = CFrame.lookAt(origin:Lerp(endPos, 0.5), endPos)
    tracer.Parent = getTracerParent()

    if withGlow then
        local light = Instance.new("PointLight")
        light.Color = color
        light.Brightness = 2.5
        light.Range = math.clamp(distance * 0.4, 6, 20)
        light.Parent = tracer
    end

    local endThickness = shrinkWidth or 0.001
    TweenService:Create(tracer, TweenInfo.new(lifetime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Transparency = 1,
        Size = Vector3.new(endThickness, endThickness, distance * 0.05),
    }):Play()

    Debris:AddItem(tracer, lifetime + 0.05)
end

local function createBeamTracer(origin, endPos, color, thickness, lifetime)
    lifetime = math.clamp(tonumber(lifetime) or 0.8, 0.2, 5)

    local host = Instance.new("Part")
    host.Name = "EzekielTracerBeam"
    host.Anchored = true
    host.CanCollide = false
    host.CanQuery = false
    host.CanTouch = false
    host.Transparency = 1
    host.Size = Vector3.new(0.05, 0.05, 0.05)
    host.CFrame = CFrame.new(origin)
    host.Parent = getTracerParent()

    local att0 = Instance.new("Attachment")
    local att1 = Instance.new("Attachment")
    att0.Parent = host
    att1.Parent = host
    att0.WorldPosition = origin
    att1.WorldPosition = endPos

    local startWidth0 = thickness * 2
    local startWidth1 = thickness * 0.5

    local beam = Instance.new("Beam")
    beam.Attachment0 = att0
    beam.Attachment1 = att1
    beam.Color = ColorSequence.new(color)
    beam.Width0 = startWidth0
    beam.Width1 = startWidth1
    beam.FaceCamera = true
    beam.LightEmission = 1
    beam.LightInfluence = 0
    beam.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.05),
        NumberSequenceKeypoint.new(1, 0.35),
    })
    beam.Parent = host

    local started = tick()
    local fadeConn
    fadeConn = RunService.RenderStepped:Connect(function()
        if not host.Parent then
            fadeConn:Disconnect()
            return
        end
        local alpha = math.clamp((tick() - started) / lifetime, 0, 1)
        local fade = 1 - alpha
        beam.Width0 = startWidth0 * fade
        beam.Width1 = startWidth1 * fade
        beam.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.05 + alpha * 0.95),
            NumberSequenceKeypoint.new(1, 0.35 + alpha * 0.65),
        })
        if alpha >= 1 then
            fadeConn:Disconnect()
            host:Destroy()
        end
    end)

    Debris:AddItem(host, lifetime + 0.1)
end

_G.DrawBulletTracer = function(origin, direction)
    if not _G.Config.TracersEnabled then return end
    if typeof(origin) ~= "Vector3" or typeof(direction) ~= "Vector3" then return end
    if direction.Magnitude < 0.001 then return end

    direction = direction.Unit
    local endPos = resolveTracerEndPos(origin, direction)
    local color = _G.Config.TracerColor or Color3.fromRGB(255, 255, 0)
    local style = _G.Config.TracerStyle or "Neon"
    local lifetime = math.clamp(tonumber(_G.Config.TracerDuration) or 0.8, 0.2, 5)
    local thickness = math.clamp(_G.Config.TracerWidth or 0.05, 0.02, 0.2)

    if style == "Glow" then
        createNeonTracerPart(origin, endPos, color, thickness * 1.2, lifetime, true, 0)
    elseif style == "Beam" then
        createBeamTracer(origin, endPos, color, thickness, lifetime)
    elseif style == "Laser" then
        createNeonTracerPart(origin, endPos, color, thickness * 0.45, lifetime * 0.55, false, 0)
    elseif style == "Lightning" then
        local delta = endPos - origin
        local dist = delta.Magnitude
        local unit = delta.Unit
        local right = unit:Cross(Vector3.new(0, 1, 0))
        if right.Magnitude < 0.01 then
            right = unit:Cross(Vector3.new(1, 0, 0))
        end
        right = right.Unit
        local up = unit:Cross(right).Unit
        local points = {origin}
        for i = 1, 5 do
            local t = i / 6
            local base = origin + unit * (dist * t)
            local jitter = thickness * 5
            table.insert(points, base + right * ((math.random() - 0.5) * jitter) + up * ((math.random() - 0.5) * jitter))
        end
        table.insert(points, endPos)
        for i = 1, #points - 1 do
            createNeonTracerPart(points[i], points[i + 1], color, thickness * 0.7, lifetime * 0.85, false, 0)
        end
    else
        createNeonTracerPart(origin, endPos, color, thickness, lifetime, false, 0)
    end
end

_G.ClearBulletTracers = function()
    local parent = getTracerParent()
    for _, child in ipairs(parent:GetChildren()) do
