local function getPlayerCharacter(player)
    local folder = workspace:FindFirstChild("PlayerCharacters")
    if folder then
        local char = folder:FindFirstChild(player.Name)
        if char and char:IsA("Model") and char:FindFirstChild("HumanoidRootPart") then
            return char
        end
    end
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        return player.Character
    end
    return nil
end

local AIM_PART_ALIASES = {
    Head = {"Head"},
    Torso = {"Torso", "UpperTorso", "LowerTorso"},
    ["Left Arm"] = {"Left Arm", "LeftUpperArm", "LeftLowerArm", "LeftHand"},
    ["Right Arm"] = {"Right Arm", "RightUpperArm", "RightLowerArm", "RightHand"},
    ["Left Leg"] = {"Left Leg", "LeftUpperLeg", "LeftLowerLeg", "LeftFoot"},
    ["Right Leg"] = {"Right Leg", "RightUpperLeg", "RightLowerLeg", "RightFoot"},
}

local function resolveAimPart(char, partName)
    if not char or not partName then return nil end
    local names = AIM_PART_ALIASES[partName] or {partName}
    for _, name in ipairs(names) do
        local part = char:FindFirstChild(name)
        if part and part:IsA("BasePart") then
            return part
        end
    end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp and hrp:IsA("BasePart") then
        return hrp
    end
    return nil
end

local function estimateHeadPosition(char, fallbackPart)
    if not char or not fallbackPart then
        return fallbackPart and fallbackPart.Position
    end

    local head = char:FindFirstChild("Head")
    if head and head:IsA("BasePart") then
        return head.Position
    end

    local hum = char:FindFirstChildOfClass("Humanoid")
    local upperTorso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    if upperTorso and upperTorso:IsA("BasePart") then
        return upperTorso.Position + Vector3.new(0, upperTorso.Size.Y * 0.55, 0)
    end

    if hum then
        local hipHeight = hum.HipHeight or 2
        return fallbackPart.Position + Vector3.new(0, hipHeight + 1.1, 0)
    end

    local ok, cf, size = pcall(function()
        return char:GetBoundingBox()
    end)
    if ok and cf and size then
        return cf.Position + Vector3.new(0, size.Y * 0.32, 0)
    end

    return fallbackPart.Position
end

_G.GetTargetAimPosition = function(targetPart, aimPartName)
    if not targetPart or not targetPart:IsA("BasePart") then
        return targetPart and targetPart.Position
    end

    local char = targetPart.Parent
    aimPartName = aimPartName or targetPart.Name

    if aimPartName == "Head" or targetPart.Name == "Head" then
        if targetPart.Name == "Head" then
            return targetPart.Position
        end
        if char and char:IsA("Model") then
            return estimateHeadPosition(char, targetPart)
        end
    end

    return targetPart.Position
end

local function getSilentAimOrigin()
    local char = getPlayerCharacter(LocalPlayer) or LocalPlayer.Character
    if char then
        local head = char:FindFirstChild("Head")
        if head and head:IsA("BasePart") then
            return head.Position
        end
        local root = char:FindFirstChild("HumanoidRootPart")
        if root and root:IsA("BasePart") then
            return root.Position
        end
    end
    if Camera then
        return Camera.CFrame.Position
    end
    return nil
end

local function hasSilentAimLineOfSight(origin, targetChar, targetPos)
    if _G.Config.SilentAimWallCheck == false then
        return true
    end
    if typeof(origin) ~= "Vector3" or typeof(targetPos) ~= "Vector3" then
        return false
    end

    local delta = targetPos - origin
    local distance = delta.Magnitude
    if distance < 0.05 then
        return true
    end

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    local ignore = {}
    local localChar = getPlayerCharacter(LocalPlayer) or LocalPlayer.Character
    if localChar then
        table.insert(ignore, localChar)
    end
    if Camera then
        table.insert(ignore, Camera)
    end
    rayParams.FilterDescendantsInstances = ignore

    local ray = workspace:Raycast(origin, delta.Unit * distance, rayParams)
    if not ray then
        return true
    end
    return targetChar and ray.Instance:IsDescendantOf(targetChar)
end

local function isSilentAimValidTarget(plr)
    if not plr or plr == LocalPlayer then
        return false
    end

    local char = getPlayerCharacter(plr)
    if not char then
        return false
    end

    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then
        return false
    end

    if _G.TeamsManager then
        local teamName = _G.TeamsManager.GetAssignedTeam(plr)
        if teamName == "LOBBY" or teamName == "Admin" then
            return false
        end
        if _G.TeamsManager.IsDead(plr) then
            return false
        end
    end

    if _G.Config.SilentAimTeamCheck ~= false then
        if _G.TeamsManager then
            local alliance = _G.TeamsManager.GetAlliance(LocalPlayer, plr)
            if alliance ~= "Hostile" and alliance ~= "Neutral" then
                return false
            end
        elseif plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team then
            return false
        end
    end

    return true
end

local function predictAimPosition(aimPos, origin, velocity, bulletSpeed)
    if typeof(aimPos) ~= "Vector3" or typeof(origin) ~= "Vector3" then
        return aimPos
    end

    bulletSpeed = math.max(tonumber(bulletSpeed) or 1000, 1)
    local distance = (aimPos - origin).Magnitude
    local timeToTarget = distance / bulletSpeed

    velocity = velocity or Vector3.new(0, 0, 0)
    local predictedVelocity = Vector3.new(
        velocity.X,
        velocity.Y * 0.35,
        velocity.Z
    )

    return aimPos + predictedVelocity * timeToTarget
end

local function getSilentAimDirection(pos, gun, target, aimPartName)
    local bulletSpeed = gun and (gun:GetAttribute("Velocity") or gun:GetAttribute("BULLET_SPEED"))
        or (workspace:FindFirstChild("Gun_variables") and workspace.Gun_variables:FindFirstChild("BULLET_SPEED") and workspace.Gun_variables.BULLET_SPEED.Value)
        or 1000

    local rootPart = target.Parent and target.Parent:FindFirstChild("HumanoidRootPart")
    local velocity = rootPart and rootPart.AssemblyLinearVelocity or Vector3.new(0, 0, 0)
    local aimPos = _G.GetTargetAimPosition(target, aimPartName) or target.Position
    local predictedPos = predictAimPosition(aimPos, pos, velocity, bulletSpeed)
    local targetChar = target.Parent

    if not hasSilentAimLineOfSight(pos, targetChar, predictedPos) then
        return nil
    end

    local delta = predictedPos - pos
    if delta.Magnitude < 0.001 then
        return nil
    end
    return delta.Unit
end

_G.GetBestTarget = function()
    local bestPart = nil
    local bestPartName = nil
    local shortestDist = _G.Config.FOVSize
    local aimOrigin = getSilentAimOrigin()

    for _, plr in ipairs(Players:GetPlayers()) do
        if not isSilentAimValidTarget(plr) then continue end

        local char = getPlayerCharacter(plr)
        if not char then continue end

        -- если у цели есть крылья (RightWing + LeftWing) — скипаем TargetParts, стреляем по UpperTorso
        local targetList = type(_G.Config.TargetParts) == "table" and _G.Config.TargetParts or {"Head", "Torso"}
        if char:FindFirstChild("RightWing") and char:FindFirstChild("LeftWing") then
            targetList = {"UpperTorso"}
        end
        for _, partName in pairs(targetList) do
            if type(partName) ~= "string" then continue end

            local part = resolveAimPart(char, partName)
            if part then
                local aimPos = _G.GetTargetAimPosition(part, partName)
                if aimOrigin and not hasSilentAimLineOfSight(aimOrigin, char, aimPos) then
                    continue
                end

                local pos, onScreen = Camera:WorldToViewportPoint(aimPos)
                if onScreen then
                    local mousePos = UserInputService:GetMouseLocation()
                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if dist < shortestDist then
                        bestPart = part
                        bestPartName = partName
                        shortestDist = dist
                    end
                end
            end
        end
    end
    return bestPart, bestPartName
end

