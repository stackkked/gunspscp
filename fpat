local function formatAccountAge(accountAge)
    if not accountAge or accountAge <= 0 then
        return "Unknown"
    end
    local years = math.floor(accountAge / 365)
    local months = math.floor((accountAge % 365) / 30)
    if years > 0 and months > 0 then
        return years .. " year" .. (years > 1 and "s" or "") .. ", " .. months .. " month" .. (months > 1 and "s" or "")
    elseif years > 0 then
        return years .. " year" .. (years > 1 and "s" or "")
    end
    return months .. " month" .. (months > 1 and "s" or "")
end

