    if now - viewmodelChamsLastMaintain < 1.5 then return end
    viewmodelChamsLastMaintain = now
    maintainArmChams()
    maintainWeaponChams()
end)

-- ==========================================
-- 7. AMMO COUNTER (XX/XXX у прицела)
-- Следит за оружием в Character (Tool), читает:
--   Tool.Ammo      (IntValue)   — патроны в стволе
--   Tool.AmmoType  (StringValue) — тип патронов (SmallCaliber/MediumCaliber/...)
--   Character.Ammo.<AmmoType>.Value — патроны в рюкзаке (StringValue как в оригинальном LocalScript)
-- Рисует XX/XXX чуть ниже центра экрана.
-- ==========================================
local AmmoCounterText = Drawing.new("Text")
AmmoCounterText.Visible = false
AmmoCounterText.Color = Color3.fromRGB(255, 255, 255)
AmmoCounterText.Size = 16
AmmoCounterText.Font = Drawing.Fonts.UI
AmmoCounterText.Outline = true
AmmoCounterText.OutlineColor = Color3.new(0, 0, 0)
AmmoCounterText.Center = true
AmmoCounterText.Transparency = 1

local function getEquippedTool()
    local char = LocalPlayer and LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChildWhichIsA("Tool")
end

local function updateAmmoCounter()
    if not _G.Config.AmmoCounterEnabled then
        AmmoCounterText.Visible = false
        return
    end

    local tool = getEquippedTool()
    if not tool then
        AmmoCounterText.Visible = false
        return
    end

    local ammoInGun = tool:FindFirstChild("Ammo")
    local ammoTypeValue = tool:FindFirstChild("AmmoType")
    if not ammoInGun or not ammoTypeValue then
        AmmoCounterText.Visible = false
        return
    end

    local currentAmmo = tonumber(ammoInGun.Value) or 0
    local ammoTypeName = tostring(ammoTypeValue.Value or "")

    local reserveAmmo = 0
    local char = LocalPlayer.Character
    local ammoFolder = char and char:FindFirstChild("Ammo")
    if ammoFolder and ammoTypeName ~= "" then
        local reserve = ammoFolder:FindFirstChild(ammoTypeName)
        if reserve then
            reserveAmmo = tonumber(reserve.Value) or 0
        end
    end

    AmmoCounterText.Text = string.format("%d/%d", currentAmmo, reserveAmmo)
    AmmoCounterText.Color = currentAmmo <= 0 and Color3.fromRGB(255, 90, 90) or Color3.fromRGB(255, 255, 255)

    local center = UserInputService:GetMouseLocation()
    -- чуть ниже прицела
    AmmoCounterText.Position = Vector2.new(center.X, center.Y + 28)
    AmmoCounterText.Visible = true
end

MainConnections.AmmoCounter = RunService.RenderStepped:Connect(function()
    if _G._ScriptUnloaded then return end
    pcall(updateAmmoCounter)
end)

-- ==========================================
-- 8. AUTO SHOOT (fixed — симуляция клика мыши через VirtualInputManager)
-- Прошлый вариант звал shoot() напрямую — если внутри кидало ошибку,
-- флаг v_u_27[tool.Name] оставался true навсегда и блокировал ВСЕ выстрелы (включая ручной).
-- Теперь симулируем LMB → триггерит нормальный input flow → useGun() → shoot()
-- с правильным state management (setState("shooting") ... setState("idle")).
-- ==========================================
local VirtualInputManager = game:GetService("VirtualInputManager")
local _autoShootLastTime = 0

MainConnections.AutoShoot = RunService.Heartbeat:Connect(function()
    if _G._ScriptUnloaded then return end
    if not _G.Config.AutoShootEnabled then return end

    local char = LocalPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildWhichIsA("Tool")
    if not tool then return end

    local target = _G.GetBestTarget()
    if not target then return end

    -- throttle ~12 выстрелов/сек (медленнее любого оружия, не палим сервер)
    local now = tick()
    if now - _autoShootLastTime < 0.08 then return end
    _autoShootLastTime = now

    local vp = Camera.ViewportSize
    local cx, cy = vp.X / 2, vp.Y / 2

    -- press + release через 40мс (имитирует реальный клик)
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
    end)
    task.delay(0.04, function()
        if _G._ScriptUnloaded then return end
        pcall(function()
            VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
        end)
    end)
end)
