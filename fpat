local CONFIG_FOLDER = "EzekielTerminal/configs"

local function ensureConfigFolder()
    if typeof(isfolder) ~= "function" or typeof(makefolder) ~= "function" then return end
    if not isfolder("EzekielTerminal") then
        makefolder("EzekielTerminal")
    end
    if not isfolder(CONFIG_FOLDER) then
        makefolder(CONFIG_FOLDER)
    end
end

local function sanitizeConfigName(name)
    local clean = tostring(name or "default"):gsub("[^%w_-]", "")
    if clean == "" then clean = "default" end
    return clean
end

local function getConfigPath(name)
    return CONFIG_FOLDER .. "/" .. sanitizeConfigName(name) .. ".json"
end

_G.ListSavedConfigs = function()
    ensureConfigFolder()
    local list = {}
    if typeof(listfiles) ~= "function" or typeof(isfolder) ~= "function" then
        return list
    end
    if not isfolder(CONFIG_FOLDER) then
        return list
    end
    local ok, files = pcall(listfiles, CONFIG_FOLDER)
    if not ok or type(files) ~= "table" then
        return list
    end
    for _, file in ipairs(files) do
        local name = tostring(file):match("([^/\\]+)%.json$")
        if name and name ~= "" then
            table.insert(list, name)
        end
    end
    table.sort(list)
    return list
end

local function getActiveConfigName()
    return sanitizeConfigName(_G.Config.ConfigFileName or "default")
end

local function rebuildConfigDropdown(dropdown, options)
    if not dropdown or not dropdown.optionsholder then return end

    local scroll = dropdown.optionsholder:FindFirstChildOfClass("ScrollingFrame")
    if not scroll then return end

    for _, child in ipairs(scroll:GetChildren()) do
        if not child:IsA("UIListLayout") then
            child:Destroy()
        end
    end

    dropdown.titles = {}
    dropdown.options = options

    local visibleCount = math.clamp(#options, 1, 12)
    scroll.Size = UDim2.new(1, 0, visibleCount, 2)
    scroll.CanvasSize = UDim2.new(0, 0, 0, 18 * math.max(#options, 1))

    local accent = dropdown.library and dropdown.library.theme and dropdown.library.theme.accent or Color3.fromRGB(225, 58, 81)
    local font = dropdown.library and dropdown.library.font or Enum.Font.RobotoMono
    local textsize = dropdown.library and dropdown.library.textsize or 13

    for _, optionName in ipairs(options) do
        local ddoptionbutton = Instance.new("TextButton")
        ddoptionbutton.AnchorPoint = Vector2.new(0, 0)
        ddoptionbutton.BackgroundTransparency = 1
        ddoptionbutton.Size = UDim2.new(1, 0, 0, 18)
        ddoptionbutton.Text = ""
        ddoptionbutton.ZIndex = 6
        ddoptionbutton.Parent = scroll

        local ddoptiontitle = Instance.new("TextLabel")
        ddoptiontitle.AnchorPoint = Vector2.new(0.5, 0)
        ddoptiontitle.BackgroundTransparency = 1
        ddoptiontitle.Size = UDim2.new(1, -10, 1, 0)
        ddoptiontitle.Position = UDim2.new(0.5, 0, 0, 0)
        ddoptiontitle.Font = font
        ddoptiontitle.Text = optionName
        ddoptiontitle.TextColor3 = Color3.fromRGB(255, 255, 255)
        ddoptiontitle.TextSize = textsize
        ddoptiontitle.TextStrokeTransparency = 0
        ddoptiontitle.TextXAlignment = Enum.TextXAlignment.Left
        ddoptiontitle.ClipsDescendants = true
        ddoptiontitle.ZIndex = 6
        ddoptiontitle.Parent = ddoptionbutton

        table.insert(dropdown.titles, ddoptiontitle)

        ddoptionbutton.MouseButton1Down:Connect(function()
            dropdown.optionsholder.Visible = false
            dropdown.open = false
            dropdown.indicator.Text = "+"
            for _, title in ipairs(dropdown.titles) do
                if title.TextColor3 == accent then
                    title.TextColor3 = Color3.fromRGB(255, 255, 255)
                end
            end
            dropdown.current = optionName
            dropdown.value.Text = optionName
            ddoptiontitle.TextColor3 = accent
            dropdown.callback(optionName)
        end)
    end

    local selected = getActiveConfigName()
    if table.find(options, selected) and dropdown.set then
        dropdown:set(selected)
    elseif #options > 0 then
        dropdown.current = options[1]
        dropdown.value.Text = options[1]
        _G.Config.ConfigFileName = options[1]
        for _, title in ipairs(dropdown.titles) do
            if title.Text == options[1] then
                title.TextColor3 = accent
            end
        end
    else
        dropdown.current = ""
        dropdown.value.Text = "(no configs)"
    end
end

_G.RefreshConfigList = function()
    local options = _G.ListSavedConfigs()
    if _G.ConfigDropdown then
        rebuildConfigDropdown(_G.ConfigDropdown, options)
    end
    return options
end

local function serializeConfig()
    local data = {}
    for k, v in pairs(_G.Config) do
        if typeof(v) == "Color3" then
            data[k] = {__type = "Color3", R = v.R, G = v.G, B = v.B}
        else
            data[k] = v
        end
    end
    return HttpService:JSONEncode(data)
end

local function deserializeConfig(json)
    local data = HttpService:JSONDecode(json)
    for k, v in pairs(data) do
        if type(v) == "table" and v.__type == "Color3" then
            _G.Config[k] = Color3.new(v.R, v.G, v.B)
        elseif k:find("Color") and type(v) == "table" and v.R and v.G and v.B then
            _G.Config[k] = Color3.new(v.R, v.G, v.B)
        else
            _G.Config[k] = v
        end
    end
end

local MENU_COLOR_PALETTE = {
    Crimson = Color3.fromRGB(225, 58, 81),
    Purple = Color3.fromRGB(168, 52, 235),
    Discord = Color3.fromRGB(88, 101, 242),
    Emerald = Color3.fromRGB(72, 200, 120),
    Orange = Color3.fromRGB(255, 140, 50),
    Cyan = Color3.fromRGB(0, 220, 255),
    Rose = Color3.fromRGB(255, 100, 150),
    Gold = Color3.fromRGB(255, 200, 40),
}
local MENU_COLOR_NAMES = {"Crimson", "Purple", "Discord", "Emerald", "Orange", "Cyan", "Rose", "Gold"}

local function roundConfigNumber(value)
    value = tonumber(value) or 0
    if typeof(math.round) == "function" then
        return math.round(value)
    end
    return math.floor(value + (value >= 0 and 0.5 or -0.5))
end

local function getMenuColorPresetName(color)
    if typeof(color) ~= "Color3" then
        return nil
    end
    for _, name in ipairs(MENU_COLOR_NAMES) do
        local preset = MENU_COLOR_PALETTE[name]
        if math.abs(preset.R - color.R) < 0.01
            and math.abs(preset.G - color.G) < 0.01
            and math.abs(preset.B - color.B) < 0.01 then
            return name
        end
    end
    return nil
end

local function normalizeConfigColor(value, fallback)
    if typeof(value) == "Color3" then
        return value
    end
    if type(value) == "table" and value.R and value.G and value.B then
        return Color3.new(value.R, value.G, value.B)
    end
    return fallback
end

