local function isItemExcluded(instance)
    if not instance then return true end
    local cat = ItemCategories[instance.Name]
    if not cat then return true end

    local excludedCats = _G.Config.ItemESPExcludedCategories
    if type(excludedCats) == "table" then
        for _, c in ipairs(excludedCats) do
            if c == cat then return true end
        end
    end

    local excludedItems = _G.Config.ItemESPExcludedItems
    if type(excludedItems) == "table" then
        for _, itemName in ipairs(excludedItems) do
            if itemName == instance.Name then return true end
        end
    end

    return false
end

local ItemEspObjects = {}
local ItemEspConns = {}
local ItemTextureCache = {}

local function toAssetImage(textureId)
    if not textureId or textureId == "" then return nil end
    local assetId = textureId:match("(%d+)")
    if assetId then
        return "rbxassetid://" .. assetId
    end
    return textureId
end

local function cacheToolTexture(tool)
    if tool:IsA("Tool") and tool.TextureId ~= "" then
        ItemTextureCache[tool.Name] = toAssetImage(tool.TextureId)
    end
end

local function scanItemTextures()
    for _, plr in ipairs(Players:GetPlayers()) do
        local backpack = plr:FindFirstChild("Backpack")
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                cacheToolTexture(tool)
            end
        end
        local char = plr.Character
        if char then
            for _, tool in ipairs(char:GetChildren()) do
                cacheToolTexture(tool)
            end
        end
    end
    for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
        if desc:IsA("Tool") then
            cacheToolTexture(desc)
        end
    end
end

local function findItemTexture(instance)
    if instance:IsA("Tool") and instance.TextureId ~= "" then
        return toAssetImage(instance.TextureId)
    end
    if ItemTextureCache[instance.Name] then
        return ItemTextureCache[instance.Name]
    end
    for _, desc in ipairs(instance:GetDescendants()) do
        if desc:IsA("Decal") and desc.Texture ~= "" then
            return toAssetImage(desc.Texture)
        end
        if desc:IsA("Texture") and desc.Texture ~= "" then
            return toAssetImage(desc.Texture)
        end
        if desc:IsA("ImageLabel") and desc.Image ~= "" then
            return desc.Image
        end
    end
    return nil
end

local function getItemAdornee(instance)
    if instance:IsA("Model") then
        return instance.PrimaryPart or instance:FindFirstChild("Handle") or instance:FindFirstChildWhichIsA("BasePart")
    elseif instance:IsA("Tool") then
        return instance:FindFirstChild("Handle")
    elseif instance:IsA("BasePart") then
        return instance
    end
    return nil
end

local function isTrackedItem(instance)
    return instance and instance.Parent and ItemCategories[instance.Name] ~= nil and not isItemExcluded(instance)
end

local function createItemEsp(instance)
    if not isTrackedItem(instance) or ItemEspObjects[instance] then return end

    local ok, err = pcall(function()
        local adornee = getItemAdornee(instance)
        if not adornee or not adornee.Parent then return end

        local category = ItemCategories[instance.Name] or "Utility"
        local iconSize = _G.Config.ItemESPIconSize or 32
        local textureImage = findItemTexture(instance)

        local billboard = Instance.new("BillboardGui")
        billboard.Name = "ItemEspIcon"
        billboard.Adornee = adornee
        billboard.Size = UDim2.new(0, iconSize + 8, 0, iconSize + 18)
        billboard.StudsOffset = Vector3.new(0, 2.2, 0)
        billboard.AlwaysOnTop = true
        billboard.LightInfluence = 0
        billboard.MaxDistance = _G.Config.ItemESPMaxDistance or 400
        billboard.Parent = getDrawParent()

        if textureImage then
            local image = Instance.new("ImageLabel")
            image.Name = "IconImage"
            image.Size = UDim2.new(1, 0, 0, iconSize)
            image.BackgroundTransparency = 1
            image.Image = textureImage
            image.ScaleType = Enum.ScaleType.Fit
            image.Parent = billboard
        else
            local frame = Instance.new("Frame")
            frame.Name = "IconFallback"
            frame.Size = UDim2.new(1, 0, 0, iconSize)
            frame.BackgroundColor3 = CategoryColors[category] or Color3.fromRGB(200, 200, 200)
            frame.BackgroundTransparency = 0.15
            frame.BorderSizePixel = 0
            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(0, 4)
            corner.Parent = frame
            frame.Parent = billboard
        end

        local distLabel = Instance.new("TextLabel")
        distLabel.Name = "DistLabel"
        distLabel.BackgroundTransparency = 1
        distLabel.Size = UDim2.new(1, 0, 0, 14)
        distLabel.Position = UDim2.new(0, 0, 0, iconSize + 2)
        distLabel.Font = Enum.Font.GothamBold
        distLabel.TextSize = 11
        distLabel.TextColor3 = CategoryColors[category]
        distLabel.TextStrokeTransparency = 0.4
        distLabel.Text = ""
        distLabel.Parent = billboard

        ItemEspObjects[instance] = {
            Billboard = billboard,
            DistLabel = distLabel,
            Instance = instance,
            Name = instance.Name,
        }
    end)

    if not ok then
        pcall(removeItemEsp, instance)
    end
end

local function safeCreateItemEsp(item)
    pcall(createItemEsp, item)
end

local function removeItemEsp(instance)
    local data = ItemEspObjects[instance]
    if not data then return end
    pcall(function()
        if data.Billboard then data.Billboard:Destroy() end
    end)
    ItemEspObjects[instance] = nil
end

_G.RefreshItemESPExclusions = function()
    for instance in pairs(ItemEspObjects) do
        if isItemExcluded(instance) then
            removeItemEsp(instance)
        end
    end
    if _G.Config.ItemESPEnabled and ItemEspConns.folder then
        for _, item in ipairs(ItemEspConns.folder:GetChildren()) do
            if isTrackedItem(item) then
                safeCreateItemEsp(item)
            end
        end
    end
end

local function clearAllItemEsp()
    for instance in pairs(ItemEspObjects) do
        removeItemEsp(instance)
    end
end

local function bindItemEspFolder(itemsFolder)
    if ItemEspConns.folder then return end
    for _, item in ipairs(itemsFolder:GetChildren()) do
        safeCreateItemEsp(item)
    end
    ItemEspConns.added = itemsFolder.ChildAdded:Connect(safeCreateItemEsp)
    ItemEspConns.removed = itemsFolder.ChildRemoved:Connect(removeItemEsp)
    ItemEspConns.folder = itemsFolder
end

local function unbindItemEspFolder()
    if ItemEspConns.added then
        ItemEspConns.added:Disconnect()
        ItemEspConns.added = nil
    end
    if ItemEspConns.removed then
        ItemEspConns.removed:Disconnect()
        ItemEspConns.removed = nil
    end
    ItemEspConns.folder = nil
end

local function enableItemESP()
    scanItemTextures()
    if not ItemEspConns.textureScan then
        local textureScanCounter = 0
        ItemEspConns.textureScan = RunService.Heartbeat:Connect(function()
            if not _G.Config.ItemESPEnabled then return end
            textureScanCounter = textureScanCounter + 1
            if textureScanCounter >= 600 then
                textureScanCounter = 0
                pcall(scanItemTextures)
            end
        end)
    end
    task.spawn(function()
        local round = workspace:WaitForChild("Round", 20)
        if not round then return end
        local itemsFolder = round:WaitForChild("Items", 20)
        if itemsFolder then
            bindItemEspFolder(itemsFolder)
        end
    end)
end

local function disableItemESP()
    unbindItemEspFolder()
    if ItemEspConns.textureScan then
        ItemEspConns.textureScan:Disconnect()
        ItemEspConns.textureScan = nil
    end
    clearAllItemEsp()
end

local function updateItemESP()
    if not _G.Config.ItemESPEnabled then return end
    local myPos = Camera.CFrame.Position
    local maxDist = _G.Config.ItemESPMaxDistance or 400
    local iconSize = _G.Config.ItemESPIconSize or 32

    for instance, data in pairs(ItemEspObjects) do
        if isItemExcluded(instance) then
            removeItemEsp(instance)
            continue
        end
        if not instance or not instance.Parent or not data.Billboard or not data.Billboard.Parent then
            removeItemEsp(instance)
            continue
        end

        local adornee = getItemAdornee(instance)
        if not adornee or not adornee.Parent then
            data.Billboard.Enabled = false
            continue
        end

        if data.Billboard.Adornee ~= adornee then
            data.Billboard.Adornee = adornee
        end

        data.Billboard.Enabled = true
        data.Billboard.MaxDistance = maxDist
        data.Billboard.Size = UDim2.new(0, iconSize + 8, 0, iconSize + 18)

        local iconHolder = data.Billboard:FindFirstChild("IconImage") or data.Billboard:FindFirstChild("IconFallback")
        if iconHolder then
            iconHolder.Size = UDim2.new(1, 0, 0, iconSize)
        end
        if data.DistLabel then
            data.DistLabel.Position = UDim2.new(0, 0, 0, iconSize + 2)
        end

        local pos
        if instance:IsA("Model") then
            local pivotOk, pivot = pcall(function() return instance:GetPivot() end)
            pos = pivotOk and pivot and pivot.Position or adornee.Position
        else
            pos = adornee.Position
        end

        if pos and data.DistLabel then
            data.DistLabel.Text = math.floor((pos - myPos).Magnitude) .. "m"
        end
    end
end

_G.SetItemESPEnabled = function(val)
    _G.Config.ItemESPEnabled = val
    if val then
        enableItemESP()
    else
        disableItemESP()
    end
end

