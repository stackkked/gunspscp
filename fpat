local oldNamecall; oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    if in_hook then return oldNamecall(self, ...) end 
    
    local method = getnamecallmethod()
    local name = tostring(self)

    if method == "FireServer" or method == "fireServer" then
        -- 1. БЛОКИРОВКА АНТИЧИТА
        if name == "SendMessage" or name == "LogAnSentryError" or name == "HookFunctionOutput" then
            local args = {...}
            local msg = tostring(args[1] or "")
            if msg:find("_PESP") or msg:find("memory") or msg:find("ClientMain") or msg:find("verification") then
                return nil
            end
        end

        -- 2. АНТИ-SPEEDHACK БАН
        if name == "HumanoidUpdater" then
            local args = table.pack(...)
            if args[1] == "step" then
                args[3] = 16 
                args[4] = 25 
                return oldNamecall(self, table.unpack(args, 1, args.n))
            end
        end
    end
    
    return oldNamecall(self, ...)
end)

