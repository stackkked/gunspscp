local StaminaConns = {}

local function setupStaminaCharacter(character)
    if not _G.Config.InfiniteStaminaEnabled or not character then return end
    character:SetAttribute("Stamina", 100)
    character:SetAttribute("stamina", 100)
    if StaminaConns[character] then return end
    StaminaConns[character] = character.AttributeChanged:Connect(function(attrName)
        if not _G.Config.InfiniteStaminaEnabled then return end
        if attrName == "Stamina" or attrName == "stamina" then
            local val = character:GetAttribute(attrName)
            if val and val < 100 then
                character:SetAttribute(attrName, 100)
            end
        end
    end)
end

_G.SetInfiniteStamina = function(enabled)
    _G.Config.InfiniteStaminaEnabled = enabled

    for char, conn in pairs(StaminaConns) do
        pcall(function() conn:Disconnect() end)
        StaminaConns[char] = nil
    end
    if StaminaConns.CharacterAdded then
        pcall(function() StaminaConns.CharacterAdded:Disconnect() end)
        StaminaConns.CharacterAdded = nil
    end

    if not enabled then return end

    local staminaFlag = workspace:FindFirstChild("staminaenabled")
    if staminaFlag then
        pcall(function() staminaFlag.Value = false end)
    end

    if LocalPlayer.Character then
        setupStaminaCharacter(LocalPlayer.Character)
    end
    StaminaConns.CharacterAdded = LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.2)
        setupStaminaCharacter(char)
    end)
end

