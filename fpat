local function disableLightingEffects(obj)
    if obj:IsA("PostEffect") or obj:IsA("BlurEffect") or obj:IsA("ColorCorrectionEffect") then
        obj.Enabled = false
    elseif obj:IsA("Atmosphere") then
        obj.Density = 0
        obj.Haze = 0
    end
end

local function restoreLightingEffects(obj, saved)
    if obj:IsA("PostEffect") or obj:IsA("BlurEffect") or obj:IsA("ColorCorrectionEffect") then
        if saved and saved.enabled ~= nil then
            obj.Enabled = saved.enabled
        else
            obj.Enabled = true
        end
    elseif obj:IsA("Atmosphere") then
        if saved then
            if saved.density ~= nil then obj.Density = saved.density end
            if saved.haze ~= nil then obj.Haze = saved.haze end
        else
            obj.Density = 0.3
        end
    end
end

local function restoreFullbrightLighting()
    local saved = _G._FullbrightOriginal
    if not saved then return end

    fullbrightApplying = true
    Lighting.Brightness = saved.brightness
    Lighting.ClockTime = saved.clockTime
    if saved.timeOfDay then
        pcall(function() Lighting.TimeOfDay = saved.timeOfDay end)
    end
    Lighting.FogEnd = saved.fogEnd
    Lighting.FogStart = saved.fogStart
    Lighting.GlobalShadows = saved.shadows
    Lighting.Ambient = saved.ambient
    Lighting.OutdoorAmbient = saved.outdoorAmbient
    if saved.geographicLatitude ~= nil then
        pcall(function() Lighting.GeographicLatitude = saved.geographicLatitude end)
    end
    fullbrightApplying = false

    for _, child in ipairs(Lighting:GetChildren()) do
        restoreLightingEffects(child, saved.effects and saved.effects[child])
    end
end

local function applyFullbrightLighting()
    if fullbrightApplying then return end
    fullbrightApplying = true

    Lighting.Brightness = 2
    Lighting.ClockTime = FULLBRIGHT_CLOCK_TIME
    pcall(function()
        Lighting.TimeOfDay = FULLBRIGHT_TIME_OF_DAY
    end)
    Lighting.FogEnd = 100000
    Lighting.FogStart = 0
    Lighting.GlobalShadows = false
    Lighting.Ambient = Color3.fromRGB(255, 255, 255)
    Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    pcall(function()
        Lighting.GeographicLatitude = 0
    end)

    fullbrightApplying = false

    for _, child in ipairs(Lighting:GetDescendants()) do
        disableLightingEffects(child)
    end
end

local function LoopFB()
    if not _G.Config.FullbrightEnabled then return end
    applyFullbrightLighting()
end

local function bindFullbrightPropertyGuards()
    _G._FullbrightPropConns = _G._FullbrightPropConns or {}

    for _, propName in ipairs(FULLBRIGHT_LOCKED_PROPS) do
        local conn = Lighting:GetPropertyChangedSignal(propName):Connect(function()
            if _G.Config.FullbrightEnabled and not fullbrightApplying then
                applyFullbrightLighting()
            end
        end)
        table.insert(_G._FullbrightPropConns, conn)
    end
end

local function startFullbrightMaintenance()
    cleanupFullbright()
    bindFullbrightPropertyGuards()

    _G._FullbrightConn = Lighting.DescendantAdded:Connect(function(child)
        task.defer(function()
            if _G.Config.FullbrightEnabled then
                disableLightingEffects(child)
            end
        end)
    end)

    _G._FullbrightLoopConn = RunService.RenderStepped:Connect(LoopFB)
end

if not (_G.Config and _G.Config.FullbrightEnabled) then
    restoreFullbrightLighting()
end

_G.SetFullbrightEnabled = function(enabled)
    _G.Config.FullbrightEnabled = enabled == true

    if enabled then
        if not _G._FullbrightOriginal then
            _G._FullbrightOriginal = {
                brightness = Lighting.Brightness,
                clockTime = Lighting.ClockTime,
                timeOfDay = Lighting.TimeOfDay,
                fogEnd = Lighting.FogEnd,
                fogStart = Lighting.FogStart,
                shadows = Lighting.GlobalShadows,
                ambient = Lighting.Ambient,
                outdoorAmbient = Lighting.OutdoorAmbient,
                geographicLatitude = Lighting.GeographicLatitude,
                effects = {},
            }
            for _, child in ipairs(Lighting:GetChildren()) do
                if child:IsA("PostEffect") or child:IsA("BlurEffect") or child:IsA("ColorCorrectionEffect") then
                    _G._FullbrightOriginal.effects[child] = { enabled = child.Enabled }
                elseif child:IsA("Atmosphere") then
                    _G._FullbrightOriginal.effects[child] = { density = child.Density, haze = child.Haze }
                end
            end
        end

        applyFullbrightLighting()
        startFullbrightMaintenance()
    else
        cleanupFullbright()
        restoreFullbrightLighting()
        _G._FullbrightOriginal = nil
    end
end

