    local color = _G.Config.WeaponChamsColor
    local stampKey = getChamStampKey("Weapon", _G.Config.WeaponChamsStyle, color)
    for part, data in pairs(ChamOriginals) do
        if data.Source == "Weapon" and part.Parent and not isChamUpToDate(part, stampKey, style, color) then
            applyWeaponChamPart(part, false)
        end
    end
end

