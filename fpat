local BanPanicWatched = {}
local BanPanicDangerPhrases = {
    -- расширенный набор ключевых слов/фраз для надёжного срабатывания
    "you have",
    "you have been",
    "you have been banned",
    "you have been kicked",
    "kicked",
    "kicked from server",
    "ban",
    "banned",
    "permanently banned",
    "ur done",
    "anti-cheat",
    "anti-cheat detected",
    "anti cheat",
    "suspicious activity",
    "suspicious activity detected",
    "violation",
    "violation detected"
}

local BanPanicIgnoredNamePatterns = {
    "chat", "bubble", "playerlist", "plist", "leaderboard", "scoreboard",
    "tooltip", "hint", "menu", "topbar", "health", "backpack", "inventory",
    "list", "tab", "slot", "template", "log", "console", "debug"
}

local function banPanicShutdown()
    pcall(function() game:Shutdown() end)
end

local function banPanicMatchesPhrase(text)
    local lower = text:lower()
    for _, phrase in ipairs(BanPanicDangerPhrases) do
        if lower:find(phrase, 1, true) then
            return true
        end
    end
    return false
end

local function isBanPanicIgnoredGui(obj)
    local current = obj
    while current and current ~= game do
        local name = current.Name:lower()
        for _, pattern in ipairs(BanPanicIgnoredNamePatterns) do
            if name:find(pattern, 1, true) then
                return true
            end
        end
        if current:IsA("ScreenGui") then
            if _G.SplixWindow and current == _G.SplixWindow.screen then
                return true
            end
            if name:find("chat", 1, true) or name:find("playerlist", 1, true) then
                return true
            end
        end
        current = current.Parent
    end
    return false
end

local function isBanPanicTextOnScreen(obj)
    if not (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) then
        return false
    end

    if isBanPanicIgnoredGui(obj) then
        return false
    end

    local text = obj.Text
    if not text or text == "" or not banPanicMatchesPhrase(text) then
        return false
    end

    if obj.TextTransparency >= 0.35 then
        return false
    end

    local current = obj
    while current do
        if current:IsA("GuiObject") and not current.Visible then
            return false
        end
        current = current.Parent
    end

    local screenGui = obj:FindFirstAncestorWhichIsA("ScreenGui")
    if not screenGui or not screenGui.Enabled then
        return false
    end

    if not obj:IsA("GuiObject") then
        return false
    end

    local absSize = obj.AbsoluteSize
    local absPos = obj.AbsolutePosition
    if absSize.X < 12 or absSize.Y < 8 then
        return false
    end

    local camera = workspace.CurrentCamera
    if camera then
        local vp = camera.ViewportSize
        if absPos.X + absSize.X < 4 or absPos.Y + absSize.Y < 4 then
            return false
        end
        if absPos.X > vp.X - 4 or absPos.Y > vp.Y - 4 then
            return false
        end
    end

    return true
end

local function checkBanPanicObject(obj)
    if not _G.Config.BanPanicEnabled then return end
    if isBanPanicTextOnScreen(obj) then
        banPanicShutdown()
    end
end

local function bindBanPanicTextWatcher(obj)
    if BanPanicWatched[obj] then return end
    if not (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) then return end

    BanPanicWatched[obj] = true
    obj:GetPropertyChangedSignal("Text"):Connect(function()
        task.defer(function()
            checkBanPanicObject(obj)
        end)
    end)
    obj:GetPropertyChangedSignal("Visible"):Connect(function()
        task.defer(function()
            checkBanPanicObject(obj)
        end)
    end)
    obj:GetPropertyChangedSignal("TextTransparency"):Connect(function()
        task.defer(function()
            checkBanPanicObject(obj)
        end)
    end)
    obj.AncestryChanged:Connect(function(_, parent)
        if not parent then
            BanPanicWatched[obj] = nil
        end
    end)
end

_G.SetBanPanicEnabled = function(enabled)
    _G.Config.BanPanicEnabled = enabled
    -- Очистим старые соединения
    for k, conn in pairs(BanPanicConns) do
        if typeof(conn) == "RBXScriptConnection" then
            pcall(function() conn:Disconnect() end)
        end
        BanPanicConns[k] = nil
    end

    if not enabled then return end

    local playerGui = LocalPlayer:WaitForChild("PlayerGui")

    local function onDescendant(obj)
        bindBanPanicTextWatcher(obj)
        task.defer(function()
            task.wait(0.08)
            checkBanPanicObject(obj)
        end)
    end

    -- Следим за `PlayerGui` и `CoreGui`, т.к. сообщения могут появляться в обоих
    BanPanicConns.PlayerGui = playerGui.DescendantAdded:Connect(onDescendant)
    BanPanicConns.CoreGui = CoreGui.DescendantAdded:Connect(onDescendant)

    for _, obj in ipairs(playerGui:GetDescendants()) do
        bindBanPanicTextWatcher(obj)
    end
    for _, obj in ipairs(CoreGui:GetDescendants()) do
        bindBanPanicTextWatcher(obj)
    end
end

task.defer(function()
    if _G.Config.BanPanicEnabled then
        pcall(_G.SetBanPanicEnabled, true)
    end
end)

