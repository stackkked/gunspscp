_G.CreateConfig = function(name)
    if typeof(writefile) ~= "function" or typeof(isfile) ~= "function" then
        _G.ShowNotify("writefile is not available in your executor", "error")
        return false
    end
    ensureConfigFolder()
    local clean = sanitizeConfigName(name)
    local path = getConfigPath(name)
    if isfile(path) then
        _G.ShowNotify("Config already exists: " .. clean, "error")
        return false
    end
    writefile(path, serializeConfig())
    _G.Config.ConfigFileName = clean
    if _G.RefreshConfigList then _G.RefreshConfigList() end
    _G.ShowNotify("Config created: " .. clean, "success")
    return true
end

_G.UpdateConfig = function(name)
    if typeof(writefile) ~= "function" or typeof(isfile) ~= "function" then
        _G.ShowNotify("writefile is not available in your executor", "error")
        return false
    end
    ensureConfigFolder()
    local clean = sanitizeConfigName(name)
    local path = getConfigPath(name)
    if not isfile(path) then
        _G.ShowNotify("Config not found: " .. clean, "error")
        return false
    end
    writefile(path, serializeConfig())
    _G.Config.ConfigFileName = clean
    if _G.RefreshConfigList then _G.RefreshConfigList() end
    _G.ShowNotify("Config updated: " .. clean, "success")
    return true
end

_G.LoadConfig = function(name)
    if typeof(readfile) ~= "function" or typeof(isfile) ~= "function" then
        _G.ShowNotify("readfile is not available in your executor", "error")
        return false
    end
    local clean = sanitizeConfigName(name)
    local path = getConfigPath(name)
    if not isfile(path) then
        _G.ShowNotify("Config not found: " .. clean, "error")
        return false
    end
    local ok, err = pcall(function()
        deserializeConfig(readfile(path))
    end)
    if not ok then
        _G.ShowNotify("Failed to load config", "error")
        warn("[CONFIG] " .. tostring(err))
        return false
    end

    ok, err = pcall(applyLoadedConfig)
    if not ok then
        _G.ShowNotify("Failed to apply config", "error")
        warn("[CONFIG] " .. tostring(err))
        return false
    end
    _G.ShowNotify("Config loaded: " .. clean, "success")
    return true
end

_G.DeleteConfig = function(name)
    local clean = sanitizeConfigName(name)
    if clean == "" or not table.find(_G.ListSavedConfigs(), clean) then
        _G.ShowNotify("Select an existing config", "error")
        return false
    end
    local path = getConfigPath(clean)
    local deleted = false
    if typeof(delfile) == "function" then
        deleted = pcall(delfile, path)
    elseif typeof(removefile) == "function" then
        deleted = pcall(removefile, path)
    end
    if not deleted then
        _G.ShowNotify("File deletion is not supported", "error")
        return false
    end
    _G.Config.ConfigFileName = ""
    if _G.RefreshConfigList then _G.RefreshConfigList() end
    _G.ShowNotify("Config deleted: " .. clean, "success")
    return true
end

