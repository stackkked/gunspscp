-- 3.86 VIEWMODEL CHAMS (ARMS + WEAPON)
-- ==========================================
local ArmChamsConns = {}
local WeaponChamsConns = {}
local ChamOriginals = {}
local ChamStamp = {}

local CHAM_STYLE_LIST = {"Plastic", "Neon", "ForceField", "Glass"}
local CHAM_STYLES = {
    Plastic = {Material = Enum.Material.SmoothPlastic, Transparency = 0, Reflectance = 0},
    Neon = {Material = Enum.Material.Neon, Transparency = 0, Reflectance = 0},
    ForceField = {Material = Enum.Material.ForceField, Transparency = 0.35, Reflectance = 0},
    Glass = {Material = Enum.Material.Glass, Transparency = 0.35, Reflectance = 0.15},
}
-- ForceField shimmer driven by texture R-channel; plain material without texture looks static
local FORCEFIELD_SHIMMER_TEX = "rbxassetid://5320397965"

local ARM_KEYWORDS = {"arm", "hand", "glove", "sleeve", "finger", "shoulder", "limb", "left", "right"}
local HAND_KEYWORDS = {"arm", "glove", "sleeve", "finger", "shoulder", "limb", "hand"}

local function getChamStyleProps(styleName)
    return CHAM_STYLES[styleName] or CHAM_STYLES.ForceField
end

local function saveChamOriginal(part, source)
    if not ChamOriginals[part] then
        ChamOriginals[part] = {
            Material = part.Material,
            Color = part.Color,
            Transparency = part.Transparency,
            Reflectance = part.Reflectance,
            TextureID = part:IsA("MeshPart") and part.TextureID or nil,
            CastShadow = part.CastShadow,
            Source = source,
            ForceMesh = nil,
        }
        local mesh = part:FindFirstChildOfClass("SpecialMesh")
        if mesh then
            ChamOriginals[part].ForceMesh = {
                Name = mesh.Name,
                MeshType = mesh.MeshType,
                MeshId = mesh.MeshId,
                TextureId = mesh.TextureId,
                Scale = mesh.Scale,
                CreatedByCham = mesh.Name == "ScpChamForceMesh",
            }
        end
    elseif source == "Weapon" or ChamOriginals[part].Source ~= "Weapon" then
        ChamOriginals[part].Source = source
    end
end

local function restoreChamPart(part)
    local data = ChamOriginals[part]
    if not data then return end
    pcall(function()
        part.Material = data.Material
        part.Color = data.Color
        part.Transparency = data.Transparency
        part.Reflectance = data.Reflectance
        part.CastShadow = data.CastShadow
        if data.TextureID ~= nil and part:IsA("MeshPart") then
            part.TextureID = data.TextureID
        end
        local forceMesh = part:FindFirstChild("ScpChamForceMesh")
        if forceMesh then
            forceMesh:Destroy()
        elseif data.ForceMesh and not data.ForceMesh.CreatedByCham then
            local mesh = part:FindFirstChild(data.ForceMesh.Name) or part:FindFirstChildOfClass("SpecialMesh")
            if mesh then
                mesh.MeshType = data.ForceMesh.MeshType
                mesh.MeshId = data.ForceMesh.MeshId
                mesh.TextureId = data.ForceMesh.TextureId
                mesh.Scale = data.ForceMesh.Scale
            end
        end
    end)
    ChamOriginals[part] = nil
    ChamStamp[part] = nil
end

local function clearPartVisualsForCham(part, style)
    local sa = part:FindFirstChildOfClass("SurfaceAppearance")
    if sa then sa:Destroy() end
    if style.Material == Enum.Material.ForceField then
        return
    end
    local tex = part:FindFirstChildOfClass("Texture") or part:FindFirstChildOfClass("Decal")
    if tex then tex:Destroy() end
    if part:IsA("MeshPart") and part.TextureID ~= "" then
        part.TextureID = ""
    end
end

local function applyForceFieldShimmer(part)
    if part:IsA("MeshPart") then
        part.TextureID = FORCEFIELD_SHIMMER_TEX
        return
    end

    local mesh = part:FindFirstChildOfClass("SpecialMesh")
    if not mesh then
        mesh = Instance.new("SpecialMesh")
        mesh.Name = "ScpChamForceMesh"
        mesh.MeshType = Enum.MeshType.Brick
        mesh.Parent = part
    end
    mesh.TextureId = FORCEFIELD_SHIMMER_TEX
end

local function hasForceFieldShimmer(part)
    if part:IsA("MeshPart") then
        return part.TextureID ~= ""
    end
    local mesh = part:FindFirstChild("ScpChamForceMesh") or part:FindFirstChildOfClass("SpecialMesh")
    return mesh and mesh.TextureId ~= ""
end

local function getChamStampKey(source, styleName, color)
    return source .. "|" .. tostring(styleName) .. "|" .. tostring(color.R) .. "|" .. tostring(color.G) .. "|" .. tostring(color.B)
end

local function isChamUpToDate(part, stampKey, style, color)
    local baseOk = ChamStamp[part] == stampKey
        and part.Material == style.Material
        and part.Color == color
        and part.Transparency == style.Transparency
    if style.Material == Enum.Material.ForceField then
        return baseOk and hasForceFieldShimmer(part)
    end
    return baseOk
end

local function clearChamsBySource(source)
    local toRestore = {}
    for part, data in pairs(ChamOriginals) do
        if data.Source == source then
            table.insert(toRestore, part)
        end
    end
    for _, part in ipairs(toRestore) do
        if part and part.Parent then
            restoreChamPart(part)
        else
            ChamOriginals[part] = nil
        end
    end
end

local function isActuallyArm(partName)
    local name = partName:lower()
    if name:find("handle", 1, true) then return false end
    for _, word in ipairs(ARM_KEYWORDS) do
        if name:find(word, 1, true) then return true end
    end
    return false
end

local function isHandPart(partName)
    local name = partName:lower()
    if name:find("handle", 1, true) then return false end
    for _, word in ipairs(HAND_KEYWORDS) do
        if name:find(word, 1, true) then return true end
    end
    return false
end

local function applyArmChamPart(part, force)
    if not _G.Config.ArmChamsEnabled then return end
    if not (part:IsA("BasePart") or part:IsA("MeshPart")) or not isActuallyArm(part.Name) then return end
    local style = getChamStyleProps(_G.Config.ArmChamsStyle)
    local color = _G.Config.ArmChamsColor
    local stampKey = getChamStampKey("Arm", _G.Config.ArmChamsStyle, color)
    if not force and isChamUpToDate(part, stampKey, style, color) then return end
    pcall(function()
        local firstApply = not ChamOriginals[part]
        saveChamOriginal(part, "Arm")
        if firstApply or force then
            clearPartVisualsForCham(part, style)
        end
        part.Material = style.Material
        part.Color = color
        part.Transparency = style.Transparency
        part.Reflectance = style.Reflectance
        if style.Material == Enum.Material.Neon then
            part.CastShadow = false
        end
        if style.Material == Enum.Material.ForceField then
            applyForceFieldShimmer(part)
        end
        ChamStamp[part] = stampKey
    end)
end

local function applyWeaponChamPart(part, force)
    if not _G.Config.WeaponChamsEnabled then return end
    if not (part:IsA("BasePart") or part:IsA("MeshPart")) or isHandPart(part.Name) then return end
    local style = getChamStyleProps(_G.Config.WeaponChamsStyle)
    local color = _G.Config.WeaponChamsColor
    local stampKey = getChamStampKey("Weapon", _G.Config.WeaponChamsStyle, color)
    if not force and isChamUpToDate(part, stampKey, style, color) then return end
    pcall(function()
        local firstApply = not ChamOriginals[part]
        saveChamOriginal(part, "Weapon")
        if firstApply or force then
            clearPartVisualsForCham(part, style)
        end
        part.Material = style.Material
        part.Color = color
        part.Transparency = style.Transparency
        part.Reflectance = style.Reflectance
        if style.Material == Enum.Material.Neon then
            part.CastShadow = false
        end
        if style.Material == Enum.Material.ForceField then
            applyForceFieldShimmer(part)
        end
        ChamStamp[part] = stampKey
    end)
end

local function disconnectArmChams()
    if ArmChamsConns.WorkspaceChild then
        pcall(function() ArmChamsConns.WorkspaceChild:Disconnect() end)
        ArmChamsConns.WorkspaceChild = nil
    end
    for model, conn in pairs(ArmChamsConns) do
        if typeof(conn) == "RBXScriptConnection" then
            pcall(function() conn:Disconnect() end)
        end
        ArmChamsConns[model] = nil
    end
end

local function disconnectWeaponChams()
    if WeaponChamsConns.ViewmodelsChild then
        pcall(function() WeaponChamsConns.ViewmodelsChild:Disconnect() end)
        WeaponChamsConns.ViewmodelsChild = nil
    end
    for model, conn in pairs(WeaponChamsConns) do
        if typeof(conn) == "RBXScriptConnection" then
            pcall(function() conn:Disconnect() end)
        end
        WeaponChamsConns[model] = nil
    end
end

local function processArmModel(model)
    if not _G.Config.ArmChamsEnabled or not model then return end
    if model.Name:find("arms", 1, true) or model.Name == "viewmodel" then
        for _, obj in ipairs(model:GetDescendants()) do
            applyArmChamPart(obj)
        end
        if not ArmChamsConns[model] then
            ArmChamsConns[model] = model.DescendantAdded:Connect(applyArmChamPart)
        end
    end
end

local function processWeaponModel(model)
    if not _G.Config.WeaponChamsEnabled or not model then return end
    for _, obj in ipairs(model:GetDescendants()) do
        applyWeaponChamPart(obj)
    end
    if not WeaponChamsConns[model] then
        WeaponChamsConns[model] = model.DescendantAdded:Connect(applyWeaponChamPart)
    end
end

_G.SetArmChamsEnabled = function(enabled)
    _G.Config.ArmChamsEnabled = enabled
    disconnectArmChams()
    clearChamsBySource("Arm")
    if not enabled then return end
    ArmChamsConns.WorkspaceChild = workspace.ChildAdded:Connect(processArmModel)
    for _, child in ipairs(workspace:GetChildren()) do
        processArmModel(child)
    end
end

_G.SetWeaponChamsEnabled = function(enabled)
    _G.Config.WeaponChamsEnabled = enabled
    disconnectWeaponChams()
    clearChamsBySource("Weapon")
    if not enabled then return end
    task.spawn(function()
        local viewmodels = workspace:WaitForChild("viewmodels", 30)
        if not viewmodels or not _G.Config.WeaponChamsEnabled then return end
        WeaponChamsConns.ViewmodelsChild = viewmodels.ChildAdded:Connect(function(model)
            task.wait(0.2)
            processWeaponModel(model)
        end)
        for _, vm in ipairs(viewmodels:GetChildren()) do
            task.spawn(function()
                task.wait(0.2)
                processWeaponModel(vm)
            end)
        end
    end)
end

_G.RefreshArmChams = function()
    if not _G.Config.ArmChamsEnabled then return end
    for part, data in pairs(ChamOriginals) do
        if data.Source == "Arm" and part.Parent then
            applyArmChamPart(part, true)
        end
    end
    for _, child in ipairs(workspace:GetChildren()) do
        processArmModel(child)
    end
end

_G.RefreshWeaponChams = function()
    if not _G.Config.WeaponChamsEnabled then return end
    for part, data in pairs(ChamOriginals) do
        if data.Source == "Weapon" and part.Parent then
            applyWeaponChamPart(part, true)
        end
    end
    local viewmodels = workspace:FindFirstChild("viewmodels")
    if viewmodels then
        for _, vm in ipairs(viewmodels:GetChildren()) do
            processWeaponModel(vm)
        end
    end
end

local function maintainArmChams()
    if not _G.Config.ArmChamsEnabled then return end
    local style = getChamStyleProps(_G.Config.ArmChamsStyle)
    local color = _G.Config.ArmChamsColor
    local stampKey = getChamStampKey("Arm", _G.Config.ArmChamsStyle, color)
    for part, data in pairs(ChamOriginals) do
        if data.Source == "Arm" and part.Parent and not isChamUpToDate(part, stampKey, style, color) then
            applyArmChamPart(part, false)
