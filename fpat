local function installBulletHandlerHooks()
    if not _G.BulletHandler or _G.AimHooked then return end

    local old_Fire = _G.BulletHandler.Fire
    local old_FireShotgun = _G.BulletHandler.FireShotgun

    _G.BulletHandler.Fire = wrapBulletClosure(function(pos, direction, gun, spread)
        if _G.Config.NoSpread then
            spread = Vector3.new(0, 0, 0)
        end

        if _G.Config.SilentAim and typeof(pos) == "Vector3" and typeof(direction) == "Vector3" then
            local target, aimPartName = _G.GetBestTarget()
            if target then
                local newDirection = getSilentAimDirection(pos, gun, target, aimPartName)
                if newDirection then
                    direction = newDirection
                end
            end
        end

        if _G.Config.TracersEnabled and typeof(pos) == "Vector3" and typeof(direction) == "Vector3" then
            task.spawn(_G.DrawBulletTracer, pos, direction)
        end

        return old_Fire(pos, direction, gun, spread)
    end)

    _G.BulletHandler.FireShotgun = wrapBulletClosure(function(pos, direction, gun, spread, pellets)
        if _G.Config.NoSpread then
            spread = Vector3.new(0, 0, 0)
        end

        if _G.Config.SilentAim and typeof(pos) == "Vector3" and typeof(direction) == "Vector3" then
            local target, aimPartName = _G.GetBestTarget()
            if target then
                local newDirection = getSilentAimDirection(pos, gun, target, aimPartName)
                if newDirection then
                    direction = newDirection
                end
            end
        end

        if _G.Config.TracersEnabled and typeof(pos) == "Vector3" and typeof(direction) == "Vector3" then
            task.spawn(function()
                local spreadVec = typeof(spread) == "Vector3" and spread or Vector3.new(0, 0, 0)
                local count = typeof(pellets) == "number" and pellets or 5
                for _ = 1, count do
                    local spreadDir = (direction + Vector3.new(
                        math.random(-spreadVec.X, spreadVec.X) / 10,
                        math.random(-spreadVec.Y, spreadVec.Y) / 10,
                        math.random(-spreadVec.X, spreadVec.X) / 10
                    )).Unit
                    _G.DrawBulletTracer(pos, spreadDir)
                end
            end)
        end

        return old_FireShotgun(pos, direction, gun, spread, pellets)
    end)

    _G.AimHooked = true
end

task.spawn(function()
    pcall(function()
        local repMods = ReplicatedStorage:WaitForChild("Modules", 20)
        if repMods and repMods:FindFirstChild("BulletHandler_client") then
            if not _G.BulletHandler then
                _G.BulletHandler = require(repMods.BulletHandler_client)
