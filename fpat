local MOD_GROUP_ID = 7357226
local MOD_ROLES = {
    ["Moderator"] = true, ["Admin"] = true, ["Super Admin"] = true,
    ["Jr.Developer"] = true, ["Developer"] = true,
    ["Monkey"] = true, ["Head Developer"] = true, ["Owner"] = true
