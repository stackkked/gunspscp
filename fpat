-- 5.5 AUTO RELOAD
-- ==========================================
local autoReloadApplied = false

_G.ApplyAutoReload = function()
    if autoReloadApplied then return end

    --[[
        GOD MODE: NON-STOP INFINITE AMMO
        Этот скрипт блокирует смену состояний, поэтому цикл стрельбы в модуле 
        никогда не прерывается, а патроны всегда на максимуме.
    ]]

    local Guns = nil
    local ReloadRemote = nil

    -- 1. ПОИСК МОДУЛЯ И РЕМОУТА
    for _, v in pairs(getloadedmodules()) do
        if v.Name == "Guns" then
            Guns = require(v)
            -- Достаем удаленное событие прямо из окружения модуля
            local env = getfenv(Guns.reload)
            if env and env.Remotes then
                ReloadRemote = env.Remotes.Reload
            end
            break
        end
    end

    if not Guns then return end

    -- 2. ХУКАЕМ ФУНКЦИЮ ВЫСТРЕЛА (SHOOT)
    -- Нам нужно найти локальную функцию shoot, которая не экспортирована
    local shootFunc = nil
    for _, v in pairs(getgc()) do
        if type(v) == "function" and getinfo(v).name == "shoot" then
            shootFunc = v
            break
        end
    end

    if shootFunc then
        local oldShoot
        oldShoot = hookfunction(shootFunc, function(firePart, tool, ...)
            -- Каждый раз перед выстрелом ставим в кеш 99 патронов.
            -- Благодаря этому условие 'if ammocache >= 1' всегда правдиво, 
            -- и оригинальный код НИКОГДА не вызовет Guns.reload(), который тормозит стрельбу.
            if Guns.ammocache then
                Guns.ammocache[tool] = 99
            end

            -- Каждые 5 выстрелов (или каждый выстрел) отправляем серверу сигнал дозарядки.
            -- Это гарантирует, что сервер всегда будет регать урон.
            if ReloadRemote then
                ReloadRemote:SendServer(tool)
            end

            return oldShoot(firePart, tool, ...)
        end)
    end

    -- 3. БЛОКИРУЕМ СМЕНУ СОСТОЯНИЯ (Чтобы цикл не прерывался)
    -- Если игра попытается переключить нас в 'idle' или 'reloading' не по нашей воле, 
    -- мы это проигнорируем, пока зажат ЛКМ.
    local UIS = game:GetService("UserInputService")
    local oldSetState = Guns.setState
    Guns.setState = newcclosure(function(state, force)
        if not checkcaller() and state ~= "shooting" then
            if UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                return false -- Запрещаем останавливать стрельбу
            end
        end
        return oldSetState(state, force)
    end)

    _G.GunsModule = Guns
    autoReloadApplied = true
end

task.spawn(function()
    while not autoReloadApplied do
        if _G.Config.AutoReload then
            _G.ApplyAutoReload()
        end
        task.wait(1)
    end
end)

