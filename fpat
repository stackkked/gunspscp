_G.ShowNotify = function(message, notifyType)
    notifyType = notifyType or "info"
    local accent = Color3.fromRGB(225, 58, 81)
    local colors = {
        success = Color3.fromRGB(72, 200, 120),
        error = Color3.fromRGB(225, 80, 80),
        info = accent,
    }
    local barColor = colors[notifyType] or colors.info

    if NotifyActive then
        pcall(function() NotifyActive:Destroy() end)
        NotifyActive = nil
    end

    local gui = Instance.new("ScreenGui")
    gui.Name = "ProjectMenuNotify"
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.DisplayOrder = 10000
    gui.Parent = getNotifyParent()

    local frame = Instance.new("Frame")
    frame.AnchorPoint = Vector2.new(0.5, 0)
    frame.Position = UDim2.new(0.5, 0, 0, -50)
    frame.Size = UDim2.new(0, 320, 0, 42)
    frame.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    frame.BackgroundTransparency = 0.15
    frame.BorderSizePixel = 0
    frame.Parent = gui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = frame

    local stroke = Instance.new("UIStroke")
    stroke.Color = barColor
    stroke.Thickness = 1.5
    stroke.Transparency = 0.2
    stroke.Parent = frame

    local accentBar = Instance.new("Frame")
    accentBar.Size = UDim2.new(0, 4, 1, -8)
    accentBar.Position = UDim2.new(0, 6, 0, 4)
    accentBar.BackgroundColor3 = barColor
    accentBar.BorderSizePixel = 0
    accentBar.Parent = frame

    local accentCorner = Instance.new("UICorner")
    accentCorner.CornerRadius = UDim.new(0, 3)
    accentCorner.Parent = accentBar

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 16, 0, 0)
    label.Size = UDim2.new(1, -22, 1, 0)
    label.Font = Enum.Font.GothamMedium
    label.Text = tostring(message)
    label.TextColor3 = Color3.fromRGB(240, 240, 240)
    label.TextSize = 14
    label.TextWrapped = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Center
    label.Parent = frame

    NotifyActive = gui

    TweenService:Create(frame, TweenInfo.new(0.45, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, 0, 0, 18)
    }):Play()

    task.delay(2.8, function()
        if not gui.Parent then return end
        local out = TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(0.5, 0, 0, -50),
            BackgroundTransparency = 1
        })
        TweenService:Create(label, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.5), {Transparency = 1}):Play()
        out:Play()
        out.Completed:Wait()
        if NotifyActive == gui then NotifyActive = nil end
        pcall(function() gui:Destroy() end)
    end)
end

