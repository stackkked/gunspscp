                if not _G.BulletHandler and RepMods:FindFirstChild("BulletHandler_client") then _G.BulletHandler = require(RepMods.BulletHandler_client) end
            end
            
            -- Прямой хук на отдачу с защитой от NaN (черного экрана)
            if _G.GunsModule and not _G.RecoilHooked then
                local old_getRecoil = _G.GunsModule.getRecoilMultiplier
                _G.GunsModule.getRecoilMultiplier = function(...)
                    local m, o = old_getRecoil(...)
                    
                    -- Проверяем тип возвращаемых значений, если не число — заменяем на дефолт
                    if typeof(m) ~= "number" then m = 1 end
                    if typeof(o) ~= "number" then o = 0 end
                    
                    local factor = (_G.Config.RecoilScale or 100) / 100
                    return m * factor, o * factor
                end
                _G.RecoilHooked = true
            end

            -- Хук BulletHandler (silent aim + tracers)
            installBulletHandlerHooks()
        end)

        if _G.GunsModule and _G.TeamsManager and _G.Network and _G.BulletHandler then 
            break 
        end
    end
end)

