local function updateESPChams(d, char, color, enabled, outlineOverride)
    if not d then return end
    if not enabled or not _G.Config.ESPShowChams or not char then
        if d.Chams then d.Chams.Enabled = false end
        return
    end
    if not d.Chams or not d.Chams.Parent then
        local hl = Instance.new("Highlight")
        hl.Name = "TeleportESPCham"
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = getDrawParent()
        d.Chams = hl
    end
    local fillColor = color:Lerp(Color3.new(1, 1, 1), 0.12)
    local outlineColor = outlineOverride or color:Lerp(Color3.new(0, 0, 0), 0.45)
    d.Chams.Adornee = char
    d.Chams.FillColor = fillColor
    d.Chams.FillTransparency = _G.Config.ESPChamFillTransparency
    d.Chams.OutlineColor = outlineColor
    d.Chams.OutlineTransparency = _G.Config.ESPChamOutlineTransparency
    d.Chams.Enabled = true
end

local function getScreenBounds(char, camera)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local top = hrp.Position + Vector3.new(0, 2.8, 0)
    local bottom = hrp.Position - Vector3.new(0, 3.2, 0)
    local topScreen, onTop = camera:WorldToViewportPoint(top)
    local bottomScreen, onBottom = camera:WorldToViewportPoint(bottom)
    if not onTop and not onBottom then return nil, false end
    local screenH = math.abs(topScreen.Y - bottomScreen.Y)
    local screenW = screenH * 0.45
    local cx = topScreen.X
    return {
        left = cx - screenW * 0.5,
        right = cx + screenW * 0.5,
        top = topScreen.Y,
        bottom = bottomScreen.Y,
        cx = cx,
        w = screenW,
        h = screenH,
    }, true
end

local function espUpdate()
    if not _G.Config.ESPEnabled then return end
    espUpdateCounter = espUpdateCounter + 1
    if espUpdateCounter < espUpdateFrequencyMobile then return end
    espUpdateCounter = 0

    local camera = workspace.CurrentCamera
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local d = ESPObjects[player]
        if not d then continue end

        local char = getPlayerCharacter(player)
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local dist = (myRoot and hrp) and math.floor((hrp.Position - myRoot.Position).Magnitude) or nil
        local inRange = dist and dist <= _G.Config.ESPMaxDistance
        local alive = hum and hum.Health > 0

        -- Teammates filter: если ESPShowTeammates выключен и игрок союзник — не рисуем ESP
        local isTeammate = false
        if not _G.Config.ESPShowTeammates then
            if _G.TeamsManager and _G.TeamsManager.GetAlliance then
                local alliance = _G.TeamsManager.GetAlliance(LocalPlayer, player)
                if alliance == "Friendly" then
                    isTeammate = true
                end
            elseif player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team then
                isTeammate = true
            end
        end

        if isTeammate then
            updateESPChams(d, char, getTeamColor(player), false)
            d.Box.Visible = false
            d.hpBarBg.Visible = false
            d.hpBarFill.Visible = false
            d.nameText.Visible = false
            d.tagText.Visible = false
            d.hpText.Visible = false
            d.distText.Visible = false
            continue
        end

        if not char or not hrp or not inRange or not alive or not hum then
            updateESPChams(d, char, getTeamColor(player), false)
            d.Box.Visible = false
            d.hpBarBg.Visible = false
            d.hpBarFill.Visible = false
            d.nameText.Visible = false
            d.tagText.Visible = false
            d.hpText.Visible = false
            d.distText.Visible = false
            continue
        end

        local bounds, onScreen = getScreenBounds(char, camera)
        if not onScreen or not bounds then
            updateESPChams(d, char, getTeamColor(player), false)
            d.Box.Visible = false
            d.hpBarBg.Visible = false
            d.hpBarFill.Visible = false
            d.nameText.Visible = false
            d.tagText.Visible = false
            d.hpText.Visible = false
            d.distText.Visible = false
            continue
        end

        local isMod = ModeratorCacheByUserId[player.UserId] ~= nil
        local col = isMod and ESP_MOD_COLOR or getTeamColor(player)
        if isMod then
            updateESPChams(d, char, ESP_MOD_CHAM_FILL, true, ESP_MOD_CHAM_OUTLINE)
        else
            updateESPChams(d, char, col, true)
        end

        local thick = isMobileESP and math.max(0.5, _G.Config.ESPBoxThickness * 0.5) or _G.Config.ESPBoxThickness
        d.Box.Visible = _G.Config.ESPShowBox
        d.Box.Color = col
        d.Box.Thickness = thick
        d.Box.Size = Vector2.new(bounds.w, bounds.h)
        d.Box.Position = Vector2.new(bounds.left, bounds.top)
        d.Box.Transparency = 1

        local barX = bounds.right + 3
        local barTopY = bounds.top
        local barBotY = bounds.bottom
        local barH = barBotY - barTopY
        local maxHp = hum.MaxHealth
        if not maxHp or maxHp <= 0 then maxHp = 100 end
        local hp = math.clamp(hum.Health, 0, maxHp)
        local frac = hp / maxHp

        if frac <= 0 then
            updateESPChams(d, char, col, false)
            d.hpBarBg.Visible = false
            d.hpBarFill.Visible = false
            d.hpText.Visible = false
            d.Box.Visible = false
            d.nameText.Visible = false
            d.tagText.Visible = false
            d.distText.Visible = false
            continue
        end

        local fillY = barBotY - barH * frac
        local hpR = math.clamp(2 * (1 - frac), 0, 1)
        local hpG = math.clamp(2 * frac, 0, 1)
        local hpCol = Color3.new(hpR, hpG, 0.1)

        d.hpBarBg.From = Vector2.new(barX, barTopY)
        d.hpBarBg.To = Vector2.new(barX, barBotY)
        d.hpBarBg.Color = Color3.fromRGB(20, 20, 20)
        d.hpBarBg.Thickness = 3
        d.hpBarBg.Transparency = 1
        d.hpBarBg.Visible = _G.Config.ESPShowHealthBar and not isMobileESP

        d.hpBarFill.From = Vector2.new(barX, fillY)
        d.hpBarFill.To = Vector2.new(barX, barBotY)
        d.hpBarFill.Color = hpCol
        d.hpBarFill.Thickness = 3
        d.hpBarFill.Transparency = 1
        d.hpBarFill.Visible = _G.Config.ESPShowHealthBar and not isMobileESP

        local ns = _G.Config.ESPNameSize
        local nameY = bounds.top - ns - 3
        if isMod then
            d.nameText.Text = "[MOD]" .. player.Name
            d.nameText.Color = ESP_MOD_COLOR
        else
            local dispName = player.DisplayName
            if dispName == "" or dispName == player.Name then
                dispName = player.Name
            end
            d.nameText.Text = dispName
            d.nameText.Color = col
        end
        d.nameText.Size = ns
        d.nameText.Position = Vector2.new(bounds.cx, nameY)
        d.nameText.Transparency = 1
        d.nameText.Visible = _G.Config.ESPShowName and not isMobileESP

        local bottomY = bounds.bottom + 2
        local hpLineH = math.max(8, ns - 1)
        local distLineH = math.max(7, ns - 2)
        local roleLineH = math.max(7, ns - 2)

        local hpPercent = math.clamp(math.floor(frac * 100 + 0.5), 0, 100)
        d.hpText.Text = hpPercent .. "%"
        d.hpText.Size = hpLineH
        d.hpText.Color = Color3.new(hpR * 0.6 + 0.5, hpG * 0.6 + 0.5, 0.4)
        d.hpText.Center = false
        d.hpText.Transparency = 1
        d.hpText.Visible = _G.Config.ESPShowHealth
        if d.hpText.Visible then
            d.hpText.Center = true
            d.hpText.Position = Vector2.new(barX + 10, (barTopY + barBotY) * 0.5)
        end

        d.distText.Text = dist .. " m"
        d.distText.Size = distLineH
        d.distText.Color = Color3.fromRGB(180, 180, 180)
        d.distText.Transparency = 1
        d.distText.Visible = _G.Config.ESPShowDistance and not isMobileESP
        if d.distText.Visible then
            d.distText.Position = Vector2.new(bounds.cx, bottomY)
            bottomY = bottomY + distLineH + 1
        end

        d.tagText.Text = getTeamLabel(player)
        d.tagText.Size = roleLineH
        d.tagText.Color = col
        d.tagText.Transparency = 1
        d.tagText.Visible = _G.Config.ESPShowRole and not isMobileESP
        if d.tagText.Visible then
            d.tagText.Position = Vector2.new(bounds.cx, bottomY)
        end
    end
end

local function hideESPObjects(d)
    if not d then return end
    d.Box.Visible = false
    d.hpBarBg.Visible = false
    d.hpBarFill.Visible = false
    d.nameText.Visible = false
    d.tagText.Visible = false
    d.hpText.Visible = false
    d.distText.Visible = false
end

local function bindESPCharacter(plr)
    if ESPPlayerConns[plr] then return end
    ESPPlayerConns[plr] = plr.CharacterAdded:Connect(function(newChar)
        task.wait(0.8)
        if _G.Config.ESPEnabled then
            pcall(function() buildESP(plr) end)
            local hum = newChar:WaitForChild("Humanoid", 5)
            if hum then
                hum.Died:Connect(function()
                    hideESPObjects(ESPObjects[plr])
                end)
            end
        end
    end)
end

local function enableESP()
    refreshModeratorCache()
    for _, p in ipairs(Players:GetPlayers()) do
        pcall(function() buildESP(p) end)
        if p ~= LocalPlayer then bindESPCharacter(p) end
    end
    if not ESPPlayerConns._Added then
        ESPPlayerConns._Added = Players.PlayerAdded:Connect(function(p)
            bindESPCharacter(p)
            p.CharacterAdded:Connect(function(newChar)
                task.wait(0.8)
                if _G.Config.ESPEnabled then
                    pcall(function() buildESP(p) end)
                    local hum = newChar:WaitForChild("Humanoid", 5)
                    if hum then
                        hum.Died:Connect(function()
                            hideESPObjects(ESPObjects[p])
                        end)
                    end
                end
            end)
        end)
        ESPPlayerConns._Removing = Players.PlayerRemoving:Connect(function(p)
            pcall(function() removeESP(p) end)
            if ESPPlayerConns[p] then
                pcall(function() ESPPlayerConns[p]:Disconnect() end)
                ESPPlayerConns[p] = nil
            end
        end)
    end
    if not ESPUpdateConn then
        ESPUpdateConn = RunService.Heartbeat:Connect(function()
            pcall(espUpdate)
        end)
    end
end

local function disableESP()
    for _, p in ipairs(Players:GetPlayers()) do
        pcall(function() removeESP(p) end)
    end
    for k, c in pairs(ESPPlayerConns) do
        pcall(function() c:Disconnect() end)
        ESPPlayerConns[k] = nil
    end
    if ESPUpdateConn then
        ESPUpdateConn:Disconnect()
        ESPUpdateConn = nil
    end
end

local function refreshAllESP()
    if not _G.Config.ESPEnabled then return end
    for _, p in ipairs(Players:GetPlayers()) do
        pcall(function() buildESP(p) end)
    end
end

local function cleanupOrphanESPInstances()
    pcall(function()
        local parent = getDrawParent()
        for _, desc in ipairs(parent:GetDescendants()) do
            if desc.Name == "TeleportESPCham" or desc.Name == "ItemEspIcon" then
                desc:Destroy()
            end
        end
    end)
    for _, plr in ipairs(Players:GetPlayers()) do
        pcall(function()
            if plr.Character then
                local hl = plr.Character:FindFirstChild("ModHighlight")
                if hl then hl:Destroy() end
            end
        end)
    end
    local charFolder = workspace:FindFirstChild("PlayerCharacters")
    if charFolder then
        for _, char in ipairs(charFolder:GetChildren()) do
            local hl = char:FindFirstChild("MidnightChams")
            if hl then hl:Destroy() end
        end
    end
end

_G.ReloadESP = function()
    local playerEsp = _G.Config.ESPEnabled
    local itemEsp = _G.Config.ItemESPEnabled
    local modEsp = _G.Config.ModESPEnabled

    disableESP()
    if itemEsp then
        disableItemESP()
    end

    cleanupOrphanESPInstances()
    espUpdateCounter = 0
    refreshModeratorCache()

    if playerEsp then
        enableESP()
    end
    if itemEsp then
        enableItemESP()
    end
    if modEsp then
        updateAllModeratorHighlights()
    end
end

_G.SetPlayerESPEnabled = function(val)
    _G.Config.ESPEnabled = val
    if val then
        if isMobileESP then
            _G.Config.ESPMaxDistance = 200
        end
        enableESP()
